---
import Layout from '../layouts/Layout.astro';
import StepGuide from '../components/StepGuide.astro';

const stepsExport = [
  {
    title: 'Logga in på den gamla instansen',
    description: 'Gå till <strong>Inställningar → Konto</strong> på din nuvarande instans.',
  },
  {
    title: 'Exportera din data',
    description: 'Under <strong>Inställningar → Importera och exportera → Exportera data</strong> kan du ladda ner dina följare, följda konton, listor och bokmärken som CSV-filer.',
    tip: 'Gör detta innan du påbörjar flytten – det är alltid bra att ha en backup.',
  },
];

const stepsMove = [
  {
    title: 'Skapa ett konto på den nya instansen',
    description: 'Registrera dig på den instans du vill flytta till. Du behöver ha ett aktivt konto där innan du kan påbörja flytten.',
  },
  {
    title: 'Skapa ett alias på det nya kontot',
    description: 'På den <strong>nya</strong> instansen: gå till <strong>Inställningar → Konto → Flytta från ett annat konto</strong>. Ange din gamla adress (t.ex. <code class="bg-gray-100 px-1 rounded text-sm font-mono">@ditt@gammalt.social</code>). Det skapar ett alias som pekar tillbaka.',
  },
  {
    title: 'Initiera flytten från det gamla kontot',
    description: 'På det <strong>gamla</strong> kontot: gå till <strong>Inställningar → Konto → Flytta till ett annat konto</strong>. Ange din nya adress och bekräfta med lösenordet.',
    tip: 'OBS: Det gamla kontot blir låst och omdirigerar besökare till det nya. Du kan inte ångra detta enkelt.',
  },
  {
    title: 'Importera följda konton',
    description: 'På det <strong>nya</strong> kontot: gå till <strong>Inställningar → Importera och exportera → Importera</strong>. Ladda upp CSV-filerna du exporterade i steg 1.',
  },
];
---

<Layout title="Flytta konto" description="Guide för att migrera ditt Mastodon-konto mellan instanser utan att förlora dina följare.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">

    <div class="mb-10">
      <p class="text-blue-700 font-semibold text-sm uppercase tracking-widest mb-3">Migration</p>
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Flytta konto</h1>
      <p class="text-lg text-gray-600">
        En av de stora fördelarna med Mastodon är att du aldrig är inlåst. Du kan flytta till en
        annan instans och ta dina följare med dig.
      </p>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg px-5 py-4 mb-10 text-sm text-blue-900">
      <p class="font-semibold mb-1">Vad följer med – och vad gör det inte?</p>
      <div class="grid sm:grid-cols-2 gap-4 mt-2">
        <div>
          <p class="font-medium mb-1 text-green-800">✓ Följer med</p>
          <ul class="space-y-1 text-gray-700">
            <li>Dina följare (automatiskt)</li>
            <li>Listan med konton du följer</li>
            <li>Listor och bokmärken</li>
            <li>Blockerade/tystade konton</li>
          </ul>
        </div>
        <div>
          <p class="font-medium mb-1 text-red-800">✗ Följer inte med</p>
          <ul class="space-y-1 text-gray-700">
            <li>Gamla inlägg</li>
            <li>Direktmeddelanden</li>
            <li>Mediekopplingar i gamla inlägg</li>
          </ul>
        </div>
      </div>
    </div>

    <h2 class="text-xl font-bold text-gray-900 mb-6">Steg 1 – Exportera din data (på gamla kontot)</h2>
    <StepGuide steps={stepsExport} />

    <h2 class="text-xl font-bold text-gray-900 mt-12 mb-6">Steg 2 – Genomför flytten</h2>
    <StepGuide steps={stepsMove} />

    <div class="mt-12 bg-gray-50 border border-gray-200 rounded-lg p-6 text-sm">
      <h3 class="font-semibold text-gray-900 mb-2">Väntetider</h3>
      <p class="text-gray-600">
        Det kan ta några timmar innan alla följare har fått den nya adressen bekräftad.
        Tålamod – det händer av sig självt.
      </p>
    </div>

  </div>
</Layout>
